# 서버 전용 (Vercel Production / Preview, 로컬 Vite 프록시). 브라우저 번들에 포함되지 않음.
GEMINI_API_KEY=your-gemini-api-key

# 국가법령정보센터 공동활용 API(lawSearch.do) OC — https://open.law.go.kr 등록 값. 둘 중 하나만 설정해도 됩니다.
LAW_GO_KR_OC=
ETHICS_LAW_OC=

# 로컬 개발만: GEMINI_API_KEY가 없을 때 Vite dev 프록시가 대체로 읽음. 프로덕션에는 두지 마세요.
# VITE_GEMINI_API_KEY=

VITE_ECO_ADMIN_PASSWORD=your-admin-password
# Optional: Unsplash random slide backgrounds (https://unsplash.com/oauth/applications)
VITE_UNSPLASH_ACCESS_KEY=

# NH증권 시세 API 설정
STOCK_NH_BASE_URL=
STOCK_NH_QUOTE_PATH=
STOCK_NH_QUOTE_METHOD=GET
STOCK_NH_QUOTE_SYMBOL_PARAM=symbol
STOCK_NH_QUOTE_USE_QUERY=true
STOCK_NH_QUOTE_API_ID=
STOCK_NH_AUTH_HEADER=Authorization
STOCK_NH_AUTH_VALUE=
STOCK_NH_CONTENT_TYPE=application/json;charset=UTF-8
STOCK_NH_TOKEN_URL=
STOCK_NH_TOKEN_METHOD=POST
STOCK_NH_CLIENT_ID=
STOCK_NH_CLIENT_SECRET=
STOCK_NH_TOKEN_BODY={"grant_type":"client_credentials","client_id":"${CLIENT_ID}","client_secret":"${CLIENT_SECRET}"}
STOCK_NH_TOKEN_FIELD=access_token
STOCK_NH_NAME_FIELD=
STOCK_NH_PRICE_FIELD=
STOCK_NH_CHANGE_FIELD=
STOCK_NH_CHANGE_RATE_FIELD=
STOCK_NH_VOLUME_FIELD=

# 키움증권 시세 API 설정
STOCK_KIWOOM_BASE_URL=https://api.kiwoom.com
STOCK_KIWOOM_QUOTE_PATH=/api/dostk/stkinfo
STOCK_KIWOOM_QUOTE_METHOD=POST
STOCK_KIWOOM_QUOTE_SYMBOL_PARAM=stk_cd
STOCK_KIWOOM_QUOTE_USE_QUERY=false
STOCK_KIWOOM_QUOTE_API_ID=ka10001
STOCK_KIWOOM_AUTH_HEADER=Authorization
STOCK_KIWOOM_AUTH_VALUE=
STOCK_KIWOOM_CONTENT_TYPE=application/json;charset=UTF-8
STOCK_KIWOOM_TOKEN_URL=/oauth2/token
STOCK_KIWOOM_TOKEN_METHOD=POST
STOCK_KIWOOM_CLIENT_ID=
STOCK_KIWOOM_CLIENT_SECRET=
STOCK_KIWOOM_TOKEN_BODY={"grant_type":"client_credentials","appkey":"${CLIENT_ID}","secretkey":"${CLIENT_SECRET}"}
STOCK_KIWOOM_TOKEN_FIELD=access_token
STOCK_KIWOOM_NAME_FIELD=
STOCK_KIWOOM_PRICE_FIELD=
STOCK_KIWOOM_CHANGE_FIELD=
STOCK_KIWOOM_CHANGE_RATE_FIELD=
STOCK_KIWOOM_VOLUME_FIELD=
